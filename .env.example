# ── Future Risk Radar — Development Environment ────────────────────────

# General
FRR_ENVIRONMENT=dev
FRR_DEBUG=true
FRR_LOG_LEVEL=INFO

# Server
FRR_HOST=0.0.0.0
FRR_PORT=8000
FRR_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database (TimescaleDB)
FRR_DB_HOST=localhost
FRR_DB_PORT=5432
FRR_DB_NAME=frr
FRR_DB_USER=frr
FRR_DB_PASSWORD=frr_dev_password
FRR_DB_POOL_SIZE=20

# Redis
FRR_REDIS_URL=redis://localhost:6379/0

# MinIO (S3-compatible)
FRR_S3_ENDPOINT=http://localhost:9000
FRR_S3_ACCESS_KEY=minioadmin
FRR_S3_SECRET_KEY=minioadmin
FRR_S3_BUCKET_RAW=frr-raw-signals
FRR_S3_BUCKET_MODELS=frr-models

# MLflow
FRR_MLFLOW_TRACKING_URI=http://localhost:5000

# JWT
FRR_JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
FRR_JWT_ALGORITHM=HS256
FRR_JWT_EXPIRE_MINUTES=60

# ── External API Keys ─────────────────────────────────────────────────
# Get a free key from https://fred.stlouisfed.org/docs/api/api_key.html
FRR_FRED_API_KEY=

# Get a key from https://www.eia.gov/opendata/register.php
FRR_EIA_API_KEY=

# Register at https://acleddata.com/
FRR_ACLED_API_KEY=
FRR_ACLED_EMAIL=

# UCDP GED API root
FRR_UCDP_API_URL=https://ucdpapi.pcr.uu.se/api

# NSF Awards API root
FRR_NSF_API_URL=https://api.nsf.gov/services/v1/awards.json

# USPTO/Patents API root
FRR_USPTO_API_URL=https://api.uspto.gov/api/v1

# UN Comtrade API root
FRR_UNCOMTRADE_API_URL=https://comtradeapi.worldbank.org/data/v1

# Google BigQuery project for GDELT
FRR_GDELT_BIGQUERY_PROJECT=
FRR_GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc

# ── Phase 2 API Keys ──────────────────────────────────────────────────
# EPO Open Patent Services — https://developers.epo.org/
FRR_EPO_CONSUMER_KEY=
FRR_EPO_CONSUMER_SECRET=

# ENTSO-E Transparency Platform — https://transparency.entsoe.eu/
FRR_ENTSOE_API_KEY=

# WTO I-TIP — https://apiportal.wto.org/
FRR_WTO_API_KEY=

# WIPO PATENTSCOPE (public scraping, no key required by default)
FRR_WIPO_API_URL=https://patentscope.wipo.int/search/en/search.jsf

# SIPRI Military Expenditure (public download)
FRR_SIPRI_DATA_URL=https://milex.sipri.org/sipri_milex/pages/download

# UNHCR Operational Data Portal (public)
FRR_UNHCR_API_URL=https://data.unhcr.org/population

# Freightos — uses FRED freight PPI proxy by default
FRR_FREIGHTOS_USE_FRED_PROXY=true

# ── Spatial Propagation ───────────────────────────────────────────────
FRR_PROPAGATION_BETA=0.15
FRR_PROPAGATION_DAMPING=0.6
FRR_PROPAGATION_HOPS=3
FRR_PROPAGATION_SPIKE_THRESHOLD=40.0

# Ingestion
FRR_INGESTION_INTERVAL_MINUTES=60
FRR_INGESTION_BATCH_SIZE=1000

# Model
FRR_MODEL_FORECAST_HORIZON_MONTHS=12
FRR_MODEL_BAYESIAN_NUM_SAMPLES=2000
FRR_MODEL_BAYESIAN_NUM_WARMUP=1000
